<?xml version="1.0" encoding="UTF-8"?>
<!--
  NexTunnel AppStream Metadata
  Place this file at: linux/packaging/myappid.appdata.xml
-->
<component type="desktop-application">
  <id>com.nextunnel.app</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>NexTunnel</name>
  <summary>Modern Proxy and VPN Manager for Linux</summary>

  <developer_name>NexTunnel</developer_name>
  <update_contact>support@nextunnel.com</update_contact>

  <description>
    <p>
      NexTunnel is an advanced proxy and VPN client built for privacy and control.
      It supports multiple backend protocols including V2Ray, Xray, Clash, and Sing-box,
      providing flexibility and performance for all kinds of network configurations.
    </p>
    <p>
      Designed with simplicity in mind, NexTunnel helps users connect securely and
      manage complex proxy configurations through a clean graphical interface.
    </p>
  </description>

  <screenshots>
    <screenshot type="default">
      <image>https://nextunnel.com/assets/nextunnel-mobile.svg</image>
      <caption>Main Interface of NexTunnel</caption>
    </screenshot>
  </screenshots>

  <launchable type="desktop-id">nextunnel.desktop</launchable>

  <icon type="stock">nextunnel</icon>

  <categories>
    <category>Network</category>
  </categories>

  <keywords>
    <keyword>NexTunnel</keyword>
    <keyword>Proxy</keyword>
    <keyword>VPN</keyword>
    <keyword>V2Ray</keyword>
    <keyword>Nekoray</keyword>
    <keyword>Xray</keyword>
    <keyword>Psiphon</keyword>
    <keyword>OpenVPN</keyword>
  </keywords>

  <mime-types>
    <mime-type>x-scheme-handler/hiddify</mime-type>
    <mime-type>x-scheme-handler/v2ray</mime-type>
    <mime-type>x-scheme-handler/v2rayn</mime-type>
    <mime-type>x-scheme-handler/v2rayng</mime-type>
    <mime-type>x-scheme-handler/clash</mime-type>
    <mime-type>x-scheme-handler/clashmeta</mime-type>
    <mime-type>x-scheme-handler/sing-box</mime-type>
  </mime-types>

  <url type="homepage">https://nextunnel.com</url>
  <url type="bugtracker">https://github.com/ivaldepablo/nextunnel-app/issues</url>
  <url type="help">https://nextunnel.com/docs</url>

  <provides>
    <binary>nextunnel</binary>
  </provides>

  <releases>
    <release version="1.0.0" date="2025-10-25">
      <description>
        <p>Initial Linux release of NexTunnel with multi-protocol support and modern UI.</p>
      </description>
    </release>
  </releases>

  <translation type="gettext">nextunnel</translation>

  <custom>
    <value key="PackageName">nextunnel</value>
    <value key="Priority">optional</value>
    <value key="Section">x11</value>
    <value key="InstalledSize">6604</value>
    <value key="Essential">false</value>
  </custom>
</component>